# ===== OpenAI（必須）=====
# OpenAI の課金 API キー
OPENAI_API_KEY=
# 使用するモデル（任意、既定: gpt-4o-mini）
OPENAI_MODEL=gpt-4o-mini
# 任意: OpenAI 互換エンドポイントの base URL（空なら OpenAI 公式）
OPENAI_BASE_URL=

# ===== ナレッジベース Django REST API =====
# Django サービスの base URL
KB_API_BASE_URL=http://localhost:8000

# 検索結果を採用するコサイン距離の上限（小さいほど厳しい、0=完全一致 / 2=逆）。
# これより関連が薄い（距離が大きい）チャンクは破棄する。既定 1.0（安全側で緩め）。
# 実データで距離分布を測ってから 0.6〜0.8 程度に絞ると無関係資料を減らせる。
SEARCH_MAX_DISTANCE=1.0
